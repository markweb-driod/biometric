# Biometric Enrollment Configuration
# Set to 'false' to use the real backend API for enrollment & verification.
# When 'true' (default), all API calls return mock/simulated responses — liveness is SKIPPED.
VITE_MOCK_API=false

# Backend API base URL
VITE_API_BASE=/api/v1

# WebSocket URL for real-time liveness checks.
# If left blank, defaults to ws://<current-host>/ws/liveness
VITE_LIVENESS_SOCKET_URL=ws://localhost:8000/ws/liveness
